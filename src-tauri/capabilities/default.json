{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-open-url",
    "store:default",
    "dialog:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://generativelanguage.googleapis.com/*" },
        { "url": "https://*.googleapis.com/*" }
      ]
    }
  ]
}
